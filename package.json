{
	"name": "js-cool",
	"description": "Collection of common JavaScript / TypeScript utilities",
	"version": "6.0.0-beta.1",
	"packageManager": "pnpm@9.1.3",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"unpkg": "dist/index.iife.min.js",
	"jsdelivr": "dist/index.iife.min.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"default": "./dist/index.js"
		},
		"./ua": {
			"types": "./dist/ua/index.d.ts",
			"require": {
				"types": "./dist/ua/index.d.ts",
				"default": "./dist/ua/index.js"
			},
			"import": {
				"types": "./dist/ua/index.d.mts",
				"default": "./dist/ua/index.mjs"
			},
			"default": "./dist/ua/index.js"
		},
		"./ua/device": {
			"types": "./dist/ua/device.d.ts",
			"require": {
				"types": "./dist/ua/device.d.ts",
				"default": "./dist/ua/device.js"
			},
			"import": {
				"types": "./dist/ua/device.d.mts",
				"default": "./dist/ua/device.mjs"
			},
			"default": "./dist/ua/device.js"
		},
		"./ua/os": {
			"types": "./dist/ua/os.d.ts",
			"require": {
				"types": "./dist/ua/os.d.ts",
				"default": "./dist/ua/os.js"
			},
			"import": {
				"types": "./dist/ua/os.d.mts",
				"default": "./dist/ua/os.mjs"
			},
			"default": "./dist/ua/os.js"
		},
		"./ua/browser": {
			"types": "./dist/ua/browser.d.ts",
			"require": {
				"types": "./dist/ua/browser.d.ts",
				"default": "./dist/ua/browser.js"
			},
			"import": {
				"types": "./dist/ua/browser.d.mts",
				"default": "./dist/ua/browser.mjs"
			},
			"default": "./dist/ua/browser.js"
		},
		"./ua/env": {
			"types": "./dist/ua/env.d.ts",
			"require": {
				"types": "./dist/ua/env.d.ts",
				"default": "./dist/ua/env.js"
			},
			"import": {
				"types": "./dist/ua/env.d.mts",
				"default": "./dist/ua/env.mjs"
			},
			"default": "./dist/ua/env.js"
		},
		"./ua/network": {
			"types": "./dist/ua/network.d.ts",
			"require": {
				"types": "./dist/ua/network.d.ts",
				"default": "./dist/ua/network.js"
			},
			"import": {
				"types": "./dist/ua/network.d.mts",
				"default": "./dist/ua/network.mjs"
			},
			"default": "./dist/ua/network.js"
		},
		"./ua/screen": {
			"types": "./dist/ua/screen.d.ts",
			"require": {
				"types": "./dist/ua/screen.d.ts",
				"default": "./dist/ua/screen.js"
			},
			"import": {
				"types": "./dist/ua/screen.d.mts",
				"default": "./dist/ua/screen.mjs"
			},
			"default": "./dist/ua/screen.js"
		},
		"./ua/types": {
			"types": "./dist/ua/types.d.ts",
			"require": {
				"types": "./dist/ua/types.d.ts",
				"default": "./dist/ua/types.js"
			},
			"import": {
				"types": "./dist/ua/types.d.mts",
				"default": "./dist/ua/types.mjs"
			},
			"default": "./dist/ua/types.js"
		},
		"./package.json": "./package.json"
	},
	"directories": {
		"dist": "dist",
		"src": "src"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"gen:version": "tsx scripts/version",
		"tag:version": "tsx scripts/tag",
		"build": "run-s clean build:{bundle,types}",
		"build:bundle": "rolldown -c",
		"build:types": "node scripts/fix-types.mjs",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"deploy": "sh scripts/deploy.sh",
		"circular": "madge dist/ -c",
		"watch": "rolldown -c -w",
		"pub": "tsx scripts/publish",
		"unpub": "tsx scripts/unpublish",
		"sync": "tsx scripts/sync",
		"workflow:publish-test": "zx scripts/workflow.mjs",
		"clean": "rm-all dist es lib temp",
		"dist": "run-s lint prettier build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint --fix .",
		"prettier": "prettier --write \"**/*.{js,ts,jsx,tsx,yml,json,md}\"",
		"typecheck": "attw --pack",
		"pub.bak": "git add . && git commit -m $npm_package_version && git pull && git push"
	},
	"dependencies": {
		"await-to-done": "^1.2.0",
		"load-source": "^1.2.0",
		"mount-css": "^1.2.0",
		"mount-image": "^1.2.0",
		"mount-script": "^1.2.0",
		"mount-style": "^1.2.0",
		"os-lang": "^3.3.1",
		"use-downloads": "^1.5.1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.17.4",
		"@eslint-sets/eslint-config": "^6.2.0",
		"@microsoft/api-extractor": "^7.57.7",
		"@types/activex-excel": "^14.0.11",
		"@types/node": "^22.19.15",
		"@vitest/coverage-istanbul": "^3.2.4",
		"@vitest/coverage-v8": "3.2.4",
		"eslint": "^9.39.4",
		"fast-glob": "^3.3.3",
		"happy-dom": "^20.8.4",
		"load-yml": "^1.4.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.1",
		"prettier-config-common": "^1.5.0",
		"reinstaller": "^3.0.2",
		"rm-all": "^1.1.1",
		"rolldown": "1.0.0-rc.9",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitepress": "^1.6.4",
		"vitest": "^3.2.4",
		"zx": "^8.8.5"
	},
	"engines": {
		"node": ">=12.20"
	},
	"sideEffects": false,
	"pnpm": {
		"peerDependencyRules": {
			"ignoreMissing": [
				"webpack"
			]
		}
	},
	"keywords": [
		"js-cool",
		"es6",
		"utilities",
		"utils",
		"typescript",
		"javascript",
		"js-library",
		"js-lib",
		"js-tools",
		"saqqdy"
	],
	"license": "MIT",
	"author": "saqqdy<https://github.com/saqqdy>",
	"homepage": "https://github.com/saqqdy/js-cool#readme",
	"bugs": {
		"url": "https://github.com/saqqdy/js-cool/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saqqdy/js-cool.git"
	}
}
